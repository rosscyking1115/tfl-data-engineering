// TfL Cycle-Hire — semantic model expressed as TMDL (Tabular Model Definition Language),
// the model-as-code that underpins the Power BI report. This is the star schema: fact tables
// (flows, journeys, deviation, live) each relate to shared dimensions (dim_date, dim_station).
//
// STATUS: hand-authored from the committed Parquet schemas and cross-checked against DuckDB.
// It has NOT been opened/verified in Power BI Desktop in this environment — treat it as the
// model spec. The guaranteed build path is powerbi/README.md (blank project + paste M + DAX);
// Tabular Editor users can also consume this TMDL directly.
//
// Only the columns used by measures/relationships/pages are listed; Power BI infers the full
// column set from each Parquet source on refresh. Measures live in powerbi/measures.dax.

// ── Parameter: where the committed gold Parquet lives (set per your local clone) ──
expression GoldExportFolder =
        "C:\dev\portfolio\tfl-data-engineering\app\gold_export" meta [
    IsParameterQuery = true,
    Type = "Text",
    IsParameterQueryRequired = true
]

// ─────────────────────────────  Dimensions  ─────────────────────────────

table dim_date
    column date_key
        dataType: int64
        sourceColumn: date_key
        isKey: true
    column date_day
        dataType: dateTime
        sourceColumn: date_day
    column year
        dataType: int64
        sourceColumn: year
    column month_name
        dataType: string
        sourceColumn: month_name
    column day_name
        dataType: string
        sourceColumn: day_name
    column is_weekend
        dataType: boolean
        sourceColumn: is_weekend

    partition dim_date = m
        mode: import
        source = ```
                let
                    Source = Parquet.Document(File.Contents(GoldExportFolder & "\dim_date.parquet"))
                in
                    Source
            ```

table dim_station
    column station_key
        dataType: string
        sourceColumn: station_key
        isKey: true
    column station_name
        dataType: string
        sourceColumn: station_name
    column dock_events
        dataType: int64
        sourceColumn: dock_events

    partition dim_station = m
        mode: import
        source = ```
                let
                    Source = Parquet.Document(File.Contents(GoldExportFolder & "\dim_station.parquet"))
                in
                    Source
            ```

// ─────────────────────────────  Facts  ─────────────────────────────

// Deliberately disconnected: certified ADR-0009 cards must not change under
// date/station slicers. The rigor export, not DAX, owns this result.
table certified_adr0009_evidence
    column evidence_artifact
        dataType: string
        sourceColumn: evidence_artifact
    column certificate_id
        dataType: string
        sourceColumn: certificate_id
        isKey: true
    column evidence_version
        dataType: string
        sourceColumn: evidence_version
    column adr_id
        dataType: string
        sourceColumn: adr_id
    column claim_class
        dataType: string
        sourceColumn: claim_class
    column permitted_claim
        dataType: string
        sourceColumn: permitted_claim
    column comparator_family
        dataType: string
        sourceColumn: comparator_family
    column cited_strike_seed
        dataType: string
        sourceColumn: cited_strike_seed
    column station_day_evidence
        dataType: string
        sourceColumn: station_day_evidence
    column min_expected_departures
        dataType: int64
        sourceColumn: min_expected_departures
    column headline_ratio
        dataType: double
        sourceColumn: headline_ratio
    column ci95_lo
        dataType: double
        sourceColumn: ci95_lo
    column ci95_hi
        dataType: double
        sourceColumn: ci95_hi
    column n_events
        dataType: int64
        sourceColumn: n_events

    partition certified_adr0009_evidence = m
        mode: import
        source = ```
                let
                    Source = Json.Document(File.Contents(GoldExportFolder & "\analysis_rigor.json")),
                    Certificate = Source[certificate],
                    Headline = Source[headline]
                in
                    #table({"evidence_artifact", "certificate_id", "evidence_version", "adr_id", "claim_class", "permitted_claim", "comparator_family", "cited_strike_seed", "station_day_evidence", "min_expected_departures", "headline_ratio", "ci95_lo", "ci95_hi", "n_events"}, {{"app/gold_export/analysis_rigor.json", Certificate[certificate_id], Certificate[evidence_version], Certificate[adr_id], Certificate[claim_class], Certificate[permitted_claim], Certificate[primary_specification][comparator_family], Certificate[primary_specification][strike_seed], "app/gold_export/demand_deviation.parquet", Certificate[primary_specification][min_expected_departures], Headline[median_ratio], Headline[ci95_lo], Headline[ci95_hi], Headline[n_events]}})
            ```

    measure 'Certified ADR-0009 Demand Ratio' =
            MAX ( certified_adr0009_evidence[headline_ratio] )
        formatString: 0.000
        displayFolder: T-CERT
        description: The locked ADR-0009 historical observed association. This is not calculated from report rows.

    measure 'Certified ADR-0009 Lower CI' =
            MAX ( certified_adr0009_evidence[ci95_lo] )
        formatString: 0.000
        displayFolder: T-CERT
        description: Lower bound of the rigor-owned 95 percent confidence interval.

    measure 'Certified ADR-0009 Upper CI' =
            MAX ( certified_adr0009_evidence[ci95_hi] )
        formatString: 0.000
        displayFolder: T-CERT
        description: Upper bound of the rigor-owned 95 percent confidence interval.

    measure 'Certified ADR-0009 Claim' =
            MAX ( certified_adr0009_evidence[permitted_claim] )
        displayFolder: T-CERT
        description: The permitted associational language from the evidence certificate.

