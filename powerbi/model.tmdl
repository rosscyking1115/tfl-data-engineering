// ─────────────────────────────  Relationships  ─────────────────────────────
// Single-direction (dimension filters fact). date_key → dim_date, station_key → dim_station.

relationship flows_date
    fromColumn: station_daily_flows.date_key
    toColumn: dim_date.date_key

relationship flows_station
    fromColumn: station_daily_flows.station_key
    toColumn: dim_station.station_key

relationship journeys_date
    fromColumn: daily_journey_stats.date_key
    toColumn: dim_date.date_key

relationship deviation_date
    fromColumn: demand_deviation.date_key
    toColumn: dim_date.date_key

relationship deviation_station
    fromColumn: demand_deviation.station_key
    toColumn: dim_station.station_key

relationship deviation_ml_date
    fromColumn: demand_deviation_ml.date_key
    toColumn: dim_date.date_key

relationship deviation_ml_station
    fromColumn: demand_deviation_ml.station_key
    toColumn: dim_station.station_key
