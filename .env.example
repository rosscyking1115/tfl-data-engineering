# Copy to .env and fill in. Never commit .env.

# TfL Unified API — register a free app key at https://api.tfl.gov.uk
TFL_APP_KEY=

# Snowflake — filled in at Phase 1 (trial signup deferred until backfill weekend)
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_ROLE=
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_DATABASE=

# Optional: Slack-compatible webhook for Airflow failure alerts (Phase 3).
# Leave empty to alert via CRITICAL log lines only.
ALERT_WEBHOOK_URL=

# Phase 5 MCP server — the read-only role it assumes (created by mcp/setup_readonly_role.sql).
SNOWFLAKE_MCP_ROLE=TFL_GOLD_READONLY

# "Ask the data" QA assistant (app/assistant.py). Optional — the Ask page is inert
# without it. Keep OUT of public Streamlit secrets (anonymous visitors would spend
# your credits). Optional: ANTHROPIC_MODEL to override the default claude-opus-4-8.
ANTHROPIC_API_KEY=
